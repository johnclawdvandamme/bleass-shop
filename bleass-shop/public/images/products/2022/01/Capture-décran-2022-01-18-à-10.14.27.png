/* SEPT 2024 */

	/* SHOP */

body.woocommerce-shop h1{
	text-align: center;
}

	/* FICHE PRODUIT */

body.product-template-default .main-content-background{
	background-color: #F8F8F8;
}

body.product-template-default .main-content-background > .grid-container{
	margin-top: 60px;
	margin-bottom: 60px;
	background-color: #ffffff;
}

.woocommerce-product-details__short-description ul li{
	list-style-type: circle!important;
}

.woocommerce .ut-shop-quantity+.single_add_to_cart_button{
	height: 48px!important;
	font-size: 1rem;
}

.woocommerce .ut-shop-quantity .qty{
	height: 32px;
}

.woocommerce .ut-shop-quantity .decrease, .woocommerce .ut-shop-quantity .increase{
	height: 30px!important;
}

.single_add_to_cart_button, .add_to_cart_button{
	background-color: rgba(0, 184, 248, 1)!important;
	color: #fff!important;
	font-size: 1rem!important;
}

.wc-tabs{
	border-top: 1px solid #ddd!important
}

.wc-tabs::before{
	display: none!important;
}

.wc-tabs > li{
	border: none!important;
	border-radius: 0!important;
	height: 50px;
}

.wc-tabs > li:hover, .wc-tabs > li.active{
	border-top: 2px solid rgba(0, 184, 248, 1)!important;
}
